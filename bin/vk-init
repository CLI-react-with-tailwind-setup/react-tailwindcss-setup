#!/usr/bin/env node

import chalk from "chalk";
import { spawn } from "child_process";
import fs from "fs";
import readline from "readline";
import ora from "ora";

// ---------------- FRAMEWORKS DATA ----------------

const FRAMEWORKS = [
  {
    name: "React",
    color: chalk.cyan,
    variants: [
      { name: "JavaScript", template: "react" },
      { name: "TypeScript", template: "react-ts" },
      { name: "JavaScript + SWC", template: "react-swc" },
      { name: "TypeScript + SWC", template: "react-swc-ts" },
    ],
  },
  {
    name: "Vue",
    color: chalk.green,
    variants: [
      { name: "JavaScript", template: "vue" },
      { name: "TypeScript", template: "vue-ts" },
    ],
  },
  {
    name: "Svelte",
    color: chalk.red,
    variants: [
      { name: "JavaScript", template: "svelte" },
      { name: "TypeScript", template: "svelte-ts" },
    ],
  },
  {
    name: "Preact",
    color: chalk.magenta,
    variants: [
      { name: "JavaScript", template: "preact" },
      { name: "TypeScript", template: "preact-ts" },
    ],
  },
  {
    name: "Solid",
    color: chalk.blue,
    variants: [
      { name: "JavaScript", template: "solid" },
      { name: "TypeScript", template: "solid-ts" },
    ],
  },
  {
    name: "Vanilla",
    color: chalk.yellow,
    variants: [
      { name: "JavaScript", template: "vanilla" },
      { name: "TypeScript", template: "vanilla-ts" },
    ],
  },
  {
    name: "Lit",
    color: chalk.hex("#324FFF"),
    variants: [
      { name: "JavaScript", template: "lit" },
      { name: "TypeScript", template: "lit-ts" },
    ],
  },
];

// CSS file path per framework base name
const CSS_FILE_MAP = {
  react: "src/index.css",
  vue: "src/style.css",
  svelte: "src/app.css",
  preact: "src/index.css",
  solid: "src/index.css",
  vanilla: "style.css",
  lit: "src/index.css",
};

// ---------------- ARGS / DEFAULTS ----------------

let projectName = null;
let tailwindVersion = null;

const rawArgs = process.argv.slice(2);

for (let i = 0; i < rawArgs.length; i++) {
  const arg = rawArgs[i];

  // --tailwind-version=4.0.0
  if (arg.startsWith("--tailwind-version=")) {
    const value = arg.split("=")[1];
    if (value) tailwindVersion = value;
    continue;
  }

  // --tailwind-version 4.0.0
  if (arg === "--tailwind-version") {
    const next = rawArgs[i + 1];
    if (next && !next.startsWith("-")) {
      tailwindVersion = next;
      i++;
    }
    continue;
  }

  if (!arg.startsWith("-") && !projectName) {
    projectName = arg;
    continue;
  }
}

let currentChild = null;

// ---------------- SIMPLE ASK HELPER ----------------

function ask(question) {
  return new Promise((resolve) => {
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout,
    });

    rl.question(question, (answer) => {
      rl.close();
      resolve(answer.trim());
    });
  });
}

// ---------------- INTERACTIVE SELECT (arrow keys) ----------------

function select(question, options) {
  return new Promise((resolve) => {
    let selected = 0;
    let firstRender = true;

    const render = () => {
      if (!firstRender) {
        // Move cursor up to overwrite previous render
        process.stdout.write(`\x1B[${options.length}A`);
      }
      firstRender = false;

      options.forEach((opt, i) => {
        const active = i === selected;
        const marker = active ? chalk.cyan("❯") : " ";
        const label = active
          ? (opt.color || chalk.cyan)(opt.name)
          : chalk.dim(opt.name);
        process.stdout.write(`\x1B[2K  ${marker} ${label}\n`);
      });
    };

    console.log(chalk.bold.green("?") + " " + chalk.bold(question));
    process.stdout.write("\x1B[?25l"); // hide cursor
    render();

    const { stdin } = process;
    stdin.setRawMode(true);
    stdin.resume();
    stdin.setEncoding("utf8");

    const onData = (key) => {
      if (key === "\x1B[A") {
        // Up arrow
        selected = (selected - 1 + options.length) % options.length;
        render();
      } else if (key === "\x1B[B") {
        // Down arrow
        selected = (selected + 1) % options.length;
        render();
      } else if (key === "\r") {
        // Enter
        stdin.setRawMode(false);
        stdin.removeListener("data", onData);
        stdin.pause();
        process.stdout.write("\x1B[?25h"); // show cursor

        const chosen = options[selected];

        // Clean up: move to question line, rewrite with answer, clear option lines
        process.stdout.write(`\x1B[${options.length + 1}A`);
        process.stdout.write(
          `\r\x1B[2K${chalk.bold.green("✔")} ${chalk.bold(question)} ${(chosen.color || chalk.cyan)(chosen.name)}\n`,
        );
        process.stdout.write("\x1B[J"); // clear from cursor to end

        resolve(chosen);
      } else if (key === "\x03") {
        // Ctrl+C
        process.stdout.write("\x1B[?25h");
        console.log(chalk.red("\n👋 Exiting..."));
        process.exit(0);
      }
    };

    stdin.on("data", onData);
  });
}

// ---------------- CTRL+C HANDLER ----------------

process.on("SIGINT", () => {
  console.log(chalk.red("\n👋 Exiting..."));

  if (currentChild) {
    try {
      if (process.platform === "win32") {
        currentChild.kill("SIGINT");
      } else {
        process.kill(-currentChild.pid, "SIGINT"); // kill entire process group
      }
    } catch (e) {
      // Process already terminated
    }
  }

  process.exit(0);
});

// ---------------- RUN COMMAND ----------------

function runCommand(command, args) {
  return new Promise((resolve, reject) => {
    const isWindows = process.platform === "win32";

    const child = spawn(command, args, {
      stdio: "inherit",
      env: process.env,
      shell: isWindows,
      detached: !isWindows,
    });

    currentChild = child;

    child.on("close", (code) => {
      currentChild = null;
      if (code === 0) resolve();
      else reject(new Error(`${command} failed`));
    });

    child.on("error", (err) => {
      currentChild = null;
      reject(err);
    });
  });
}

// ---------------- MAIN ----------------

async function main() {
  try {
    // 1. Project name
    if (!projectName) {
      const answer = await ask(
        "Project folder name? (press Enter to use current directory): ",
      );
      projectName = answer || ".";
    }

    // 2. Framework selection (arrow keys)
    const framework = await select("Select a framework:", FRAMEWORKS);

    // 3. Variant selection (arrow keys)
    const variant = await select("Select a variant:", framework.variants);
    const template = variant.template;

    // 4. Tailwind version
    if (!tailwindVersion) {
      const answer = await ask(
        "Tailwind version? (press Enter for latest v4): ",
      );
      tailwindVersion = answer || "4";
    }

    // Only block if creating a new folder that already exists
    if (projectName !== "." && fs.existsSync(projectName)) {
      console.log(chalk.red(`\n❌ Folder "${projectName}" already exists.`));
      process.exit(1);
    }

    const viteSpinner = ora(
      `⚡ Creating Vite ${framework.name} App...`,
    ).start();

    const viteArgs = [
      "create-vite@latest",
      projectName,
      "--template",
      template,
      "--no-interactive",
    ];

    // When scaffolding into the current directory, Vite silently cancels
    // if the directory is not empty unless --overwrite is passed.
    if (projectName === ".") {
      viteArgs.push("--overwrite");
    }

    await runCommand("npx", viteArgs);

    if (projectName !== ".") {
      process.chdir(projectName);
    }

    // Verify that create-vite actually scaffolded the project
    if (!fs.existsSync("package.json")) {
      viteSpinner.fail("Vite scaffolding failed — package.json not found.");
      console.log(
        chalk.red(
          "The project was not created. Make sure the target directory is valid.",
        ),
      );
      process.exit(1);
    }

    viteSpinner.succeed(`Vite ${framework.name} App Created Successfully!`);

    const installSpinner = ora("📦 Installing dependencies...").start();
    await runCommand("npm", ["install", "--no-audit", "--no-fund"]);
    installSpinner.succeed("Dependencies Installed Successfully!");

    const tailwindSpinner = ora(
      `🎨 Installing Tailwind (tailwindcss@${tailwindVersion}, @tailwindcss/vite@${tailwindVersion})...`,
    ).start();

    await runCommand("npm", [
      "install",
      "--no-audit",
      "--no-fund",
      `tailwindcss@${tailwindVersion}`,
      `@tailwindcss/vite@${tailwindVersion}`,
    ]);
    tailwindSpinner.succeed("Tailwind Installed Successfully!");

    // Get the framework base name (e.g. "react" from "react-swc-ts")
    const frameworkBase = framework.name.toLowerCase();

    configureVite();
    configureCSS(frameworkBase);

    console.log(
      chalk.green(`\n🚀 ${framework.name} + Tailwind Project Ready!`),
    );
    console.log(chalk.blue("\nStarting development server..."));

    // Spawn dev server directly without awaiting it
    const isWindows = process.platform === "win32";
    const cmd = isWindows ? "npm.cmd" : "npm";

    const devProcess = spawn(cmd, ["run", "dev"], {
      stdio: "inherit",
    });

    currentChild = devProcess;
  } catch (err) {
    console.log(chalk.red("\n❌ Setup failed or interrupted."));
    if (err?.message) {
      console.log(chalk.red(err.message));
    }
  }
}

// ---------------- CONFIGURE VITE ----------------

function configureVite() {
  // Find existing config file (could be .js or .ts depending on template)
  const configFile = fs.existsSync("vite.config.ts")
    ? "vite.config.ts"
    : "vite.config.js";

  let content = fs.readFileSync(configFile, "utf-8");

  // Add tailwind import after the last import statement
  const tailwindImport = `import tailwindcss from '@tailwindcss/vite'`;

  const lines = content.split("\n");
  let lastImportLine = -1;
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].trimStart().startsWith("import ")) {
      lastImportLine = i;
    }
  }

  if (lastImportLine >= 0) {
    lines.splice(lastImportLine + 1, 0, tailwindImport);
  } else {
    lines.unshift(tailwindImport);
  }
  content = lines.join("\n");

  // Add tailwindcss() to the plugins array
  const pluginsRegex = /plugins:\s*\[/;
  if (pluginsRegex.test(content)) {
    content = content.replace(pluginsRegex, "plugins: [\n    tailwindcss(),\n   ");
  } else if (content.includes("defineConfig({")) {
    content = content.replace(
      "defineConfig({",
      "defineConfig({\n  plugins: [tailwindcss()],",
    );
  }

  fs.writeFileSync(configFile, content);
}

// ---------------- CONFIGURE CSS ----------------

function configureCSS(frameworkBase) {
  const cssFile = CSS_FILE_MAP[frameworkBase] || "src/index.css";

  if (fs.existsSync(cssFile)) {
    // Prepend @import "tailwindcss" to existing CSS file
    const existing = fs.readFileSync(cssFile, "utf-8");
    fs.writeFileSync(cssFile, `@import "tailwindcss";\n${existing}`);
  } else {
    // Create the CSS file if it doesn't exist
    const dir = cssFile.includes("/")
      ? cssFile.split("/").slice(0, -1).join("/")
      : ".";
    if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
    fs.writeFileSync(cssFile, `@import "tailwindcss";\n`);
  }
}

main();
