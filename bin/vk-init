#!/usr/bin/env node


import chalk from "chalk";
import { spawn } from "child_process";
import fs from "fs";
import readline from "readline";
import ora from "ora";

// ---------------- ARGS / DEFAULTS ----------------

// Default project name; Tailwind version can come from CLI or prompt
let projectName = "my-app";
let tailwindVersion = null;

const rawArgs = process.argv.slice(2);

for (let i = 0; i < rawArgs.length; i++) {
  const arg = rawArgs[i];

  // --tailwind-version=4.0.0
  if (arg.startsWith("--tailwind-version=")) {
    const value = arg.split("=")[1];
    if (value) tailwindVersion = value;
    continue;
  }

  // --tailwind-version 4.0.0
  if (arg === "--tailwind-version") {
    const next = rawArgs[i + 1];
    if (next && !next.startsWith("-")) {
      tailwindVersion = next;
      i++;
    }
    continue;
  }

  // First non-option arg is project name (including ".")
  if (!arg.startsWith("-") && projectName === "my-app") {
    projectName = arg;
    continue;
  }
}

if (!projectName) {
  projectName = "my-app";
}

let currentChild = null;

// ---------------- SIMPLE ASK HELPER ----------------

function ask(question) {
  return new Promise((resolve) => {
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout
    });

    rl.question(question, (answer) => {
      rl.close();
      resolve(answer.trim());
    });
  });
}

// ---------------- CTRL+C HANDLER ----------------

process.on("SIGINT", () => {
  console.log(chalk.red("\n👋 Exiting..."));

  if (currentChild) {
    try {
      if (process.platform === "win32") {
        currentChild.kill("SIGINT");
      } else {
        process.kill(-currentChild.pid, "SIGINT"); // kill entire process group
      }
    } catch (e) {
      // Process already terminated
    }
  }

  process.exit(0);
});

// ---------------- RUN COMMAND ----------------

function runCommand(command, args) {
  return new Promise((resolve, reject) => {
    const isWindows = process.platform === "win32";
    const cmd = isWindows ? `${command}.cmd` : command;

    const child = spawn(cmd, args, {
      stdio: "inherit",
      env: process.env,
      detached: process.platform !== "win32"
    });

    currentChild = child;

    child.on("close", (code) => {
      currentChild = null;
      if (code === 0) resolve();
      else reject(new Error(`${command} failed`));
    });
  });
}

// ---------------- MAIN ----------------

async function main() {
  try {
    // If Tailwind version was not provided via CLI, ask the user (like Vite style prompts)
    if (!tailwindVersion) {
      const answer = await ask("Tailwind version? (press Enter for latest v4): ");
      tailwindVersion = answer || "4";
    }

    const viteSpinner = ora("⚡ Creating Vite React App...").start();

    await runCommand("npx", [
      "create-vite@latest",
      projectName,
      "--template",
      "react",
      "--no-interactive"
    ]);
    viteSpinner.succeed("Vite React App Created Successfully!")
    if (projectName !== ".") {
      process.chdir(projectName);
    }

    const installSpinner = ora("📦 Installing dependencies...").start();
    await runCommand("npm", ["install"]);
    installSpinner.succeed("Dependencies Installed Successfully!");

   
      const tailwindSpinner = ora(
        `🎨 Installing Tailwind (tailwindcss@${tailwindVersion}, @tailwindcss/vite@${tailwindVersion})...`
      ).start();
  
    await runCommand("npm", [
      "install",
      `tailwindcss@${tailwindVersion}`,
      `@tailwindcss/vite@${tailwindVersion}`
    ]);
    tailwindSpinner.succeed("Tailwind Installed Successfully!");

    configureVite();
    configureCSS();

    console.log(chalk.green("\n🚀 Project Ready With Tailwind!"));
    console.log(chalk.blue("\nStarting development server..."));
    
    // Spawn dev server directly without awaiting it (so user can interact with terminal)
    const isWindows = process.platform === "win32";
    const cmd = isWindows ? "npm.cmd" : "npm";
    
    const devProcess = spawn(cmd, ["run", "dev"], {
      stdio: "inherit",
    });

    currentChild = devProcess;

  } catch (err) {
    console.log(chalk.red("\n❌ Setup failed or interrupted."));
  if (err?.message) {
    console.log(chalk.red(err.message));
  }
}
}
// ---------------- CONFIGURE VITE ----------------

function configureVite() {
  const content = `import { defineConfig } from 'vite'
import tailwindcss from '@tailwindcss/vite'
import react from '@vitejs/plugin-react'

// https://vite.dev/config/
export default defineConfig({
  plugins: [
    tailwindcss(),
    react()
  ],
})`

  fs.writeFileSync("vite.config.js", content);
}

// ---------------- CONFIGURE CSS ----------------

function configureCSS() {
  fs.writeFileSync("src/index.css", `@import "tailwindcss";`);
}

main();
